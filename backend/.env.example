NODE_ENV=production
PORT=3001

# Use absolute paths on the cloud server.
DATABASE_PATH=/var/www/DM-sys/backend/database.sqlite
UPLOAD_DIR=/var/www/DM-sys/backend/uploads

# Generate a long random value before deployment.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

# Used only when the users table is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Leave empty for same-origin Nginx deployment.
CORS_ORIGIN=
